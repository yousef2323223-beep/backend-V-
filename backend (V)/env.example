# ── Database ──────────────────────────────────────────
# PostgreSQL connection string
# Local:  postgresql://USER:PASSWORD@localhost:5432/vynorpay
# Docker: postgresql://postgres:postgres@db:5432/vynorpay
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vynorpay"

# ── JWT ──────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-random-64-char-secret"
JWT_EXPIRES_IN="7d"

# ── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────
# Frontend URL (for CORS)
CLIENT_URL="http://localhost:3000"

# ── File uploads (optional — Cloudinary) ─────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
